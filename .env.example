# =========================================================================
# Campus Kartt — Environment Configuration (Template)
# Copy this file to .env and fill in your values
# =========================================================================

# -------------------------------------------------------------------------
# Supabase Configuration
# -------------------------------------------------------------------------
# Your Supabase Project URL (found under Project Settings > API)
SUPABASE_URL=your_supabase_project_url

# Your Supabase Public Anon Key (found under Project Settings > API)
SUPABASE_ANON_KEY=your_supabase_anon_key

# -------------------------------------------------------------------------
# Cloudinary Configuration (Photo Uploads)
# -------------------------------------------------------------------------
# Your Cloudinary Cloud Name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Your Cloudinary Unsigned Upload Preset name
CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# -------------------------------------------------------------------------
# Razorpay Configuration (Payment Gateway)
# -------------------------------------------------------------------------
# Razorpay API Key ID (use rzp_test_... for sandbox and rzp_live_... for production)
RAZORPAY_KEY_ID=your_razorpay_key_id
